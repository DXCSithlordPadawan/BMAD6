# .env.example — copy to .env and fill in values before running
# NEVER commit .env to source control

# REQUIRED: at least 32 random characters; generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me_with_a_random_64_char_hex_string

# Set to "1" only for local development — NEVER in production
FLASK_DEBUG=0

# ── HTTPS Support ─────────────────────────────────────────────────────────────
# Set HTTPS_ENABLED=1 to start Flask with TLS directly (e.g. for local HTTPS).
# For production, TLS should be terminated at a reverse proxy (nginx, Traefik).
# If using a reverse proxy, leave HTTPS_ENABLED=0.
HTTPS_ENABLED=0

# Paths to TLS certificate and private key (PEM format).
# Required only when HTTPS_ENABLED=1.
# SSL_CERT_FILE=/etc/ssl/certs/bmad.crt
# SSL_KEY_FILE=/etc/ssl/private/bmad.key
