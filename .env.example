# .env.example — copy to .env and fill in values before running
# NEVER commit .env to source control

# REQUIRED: at least 32 random characters; generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me_with_a_random_64_char_hex_string

# Set to "1" only for local development — NEVER in production
FLASK_DEBUG=0
